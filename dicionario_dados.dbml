Table TV_FILTROAPROVACAOTECNICA {
  HANDLE integer [pk not null] // Código
  Z_GRUPO integer [not null [ref: > FI_LOTES.HANDLE]] // Grupo AGENCIADIGITODEP S Agência dígito FI_SOLICITACAODEPOSITOS NUMEROIDDEP S Número id FI_SOLICITACAODEPOSITOS CONTACORRENTEDEP S Conta corrente FI_SOLICITACAODEPOSITOS CONTADIGITODEP S Conta dígito FI_SOLICITACAODEPOSITOS INFORMACAOVERSODEP S Informação verso FI_SOLICITACAODEPOSITOS LINHADIGITAVELDEP S Linha digitável FI_SOLICITACAODEPOSITOS AGENCIAPAG S Agência FI_SOLICITACAOPAGAMENTOS AGENCIADIGITOPAG S Agência dígito FI_SOLICITACAOPAGAMENTOS CONTACORRENTEPAG S Conta corrente FI_SOLICITACAOPAGAMENTOS CONTADIGITOPAG S Conta dígito FI_SOLICITACAOPAGAMENTOS INFORMACAOVERSOPAG S Informação verso FI_SOLICITACAOPAGAMENTOS LINHADIGITAVELPAG S Linha digitável FI_SOLICITACAOPAGAMENTOS AGENCIAADTREEMB S Agência FI_LOTES AGENCIADIGITOADTREEMB S Agência dígito FI_LOTES CONTACORRENTEADTREEMB S Conta corrente FI_LOTES CONTADIGITOADTREEMB S Conta dígito FI_LOTES INFORMACAOVERSOADTREEMB S Informação verso
  TIPOPAGAMENTODEP integer // Tipo pagamento
  TIPOPAGAMENTOPAG integer // Tipo pagamento
  TIPOPESSOADEP integer // Tipo pessoa
  TIPOPESSOAPAG integer // Tipo pessoa
  TIPOPESSOAADTREEMB integer [[ref: > FI_TIPODESPESAS.HANDLE]] // Tipo pessoa CONTACONTABILDEP S Conta contábil FN_CONTAS CENTROCUSTODEP S Centro de custo CT_CC OBJETODEP S Objeto PR_OBJETODEPOSITOS DESPESADEP S Despesa
  TRANSFERENCIABANCDEP integer [[ref: > FN_GUIASPAGAMENTOS.HANDLE]] // Transferências bancárias BANCODEP S Banco GN_BANCOS GUIAPAGAMENTODEP S Guia de pagamento
  CONVENIODEP varchar(1) [[ref: > FI_SOLICITACAOPAGAMENTOS.HANDLE]] // Convênio PESSOAFAVORECIDADEP S Favorecida GN_PESSOAS PROCESSOPAG S Pasta PR_PROCESSOS IDENTIFICADORPAG S Identificador
  GERARPARCPAG integer [[ref: > PR_CATEGORIAOBJETODEPOSITO.HANDLE]] // Gerar parcelas BANCOPAG S Banco GN_BANCOS PROCESSODEP S Pasta PR_PROCESSOS IDENTIFICADORDEP S Identificador FI_SOLICITACAODEPOSITOS CATEGORIADEP S Categoria
  SOLICITACAODEPOSITO varchar(1) // Solicitação depósito
  SOLICITACAOPAGAMENTO varchar(1) // Solicitação pagamento
  SOLICADIANTREEMBOLSO varchar(1) // Solic. adiantamento ou reembolso
  TITULOTAREFA varchar(250) // Titulo da tarefa contém
  PERIODOINICIAL Data // De:
  PERIODOFINAL Data // Até
  VENCIMENTOINICIAL Data // De:
  VENCIMENTOFINAL Data [[ref: > CT_CC.HANDLE]] // Até DESPESAADTREEMB S Despesa FI_TIPODESPESAS CONTACONTABILADTREEMB S Conta contábil FN_CONTAS CENTROCUSTOADTREEMB S Centro de custo
  TIPOSOLICITACAOADTREEMB integer // Tipo solicitação GERARPARCADTREEMB S Gerar parcelas TIPOPAGAMENTOADTREEMB S Tipo de pagamento
  TRANSFERENCIABANCADTREEMB integer [[ref: > PR_CATEGORIAS.HANDLE]] // Transferências bancárias BANCOADTREEMB S Banco GN_BANCOS PESSOAFAVORECIDAADTREEMB S Favorecida GN_PESSOAS CATEGORIAPAG S Categoria
  EMATRASO varchar(1) // Em atraso
  GERAPARCELASDEP integer [[ref: > FN_GUIASPAGAMENTOS.HANDLE]] // Gerar parcelas AGENCIADEP S Agência FI_SOLICITACAODEPOSITOS PROCESSOADTREEMB S Pasta PR_PROCESSOS IDENTIFICADORADTREEMB S Identificador lote FI_LOTES GUIAPAGAMENTOPAG S Guia de pagamento
  CONVENIOPAG varchar(1) [[ref: > FI_TIPODESPESAS.HANDLE]] // Convênio PESSOAFAVORECIDAPAG S Favorecida GN_PESSOAS CONTACONTABILPAG S Conta contábil FN_CONTAS CENTROCUSTOPAG S Centro de custo CT_CC DESPESAPAG S Despesa
  UTILIZADEPPAGAMENTO integer // Utiliza depósito para pagamento TRANSFERENCIABANCPAG
}

